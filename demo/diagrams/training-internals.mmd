%% sklearn Training Internals

flowchart TD
    A["🧪 Experiment<br/>target_column + problem_type"] --> B["📂 Load Dataset<br/>pd.read_csv(file_path)"]
    B --> C{"🔀 Split<br/>train_test_split<br/>80/20"}
    C --> D["🏷 LabelEncoder<br/>encode object columns"]
    D --> E{"problem_type?"}

    E -->|classification| F["🌲 RandomForestClassifier<br/>n=100, seed=42"]
    E -->|regression| G["🌲 RandomForestRegressor<br/>n=100, seed=42"]

    F --> H["model.fit(X_train, y_train)"]
    G --> H
    H --> I["model.predict(X_test)"]

    I --> J{"classification?"}
    J -->|yes| K["📊 accuracy_score"]
    J -->|no| L["📊 mse + r2_score"]

    K --> M["📈 MLflow Track"]
    L --> M

    M --> N["log_metric(accuracy/mse/r2)"]
    N --> O["log_model(sklearn model)"]
    O --> P["experiment.mlflow_run_id = run_id"]
    P --> Q["experiment.status = 'completed'"]

