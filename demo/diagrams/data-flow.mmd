%% ML Platform Complete Data Flow

flowchart LR
    U["📂 CSV Upload<br/>mlp data upload"] --> P["📊 Profile<br/>pandas profiling<br/>mean/std/hist/top_values"]
    P --> E["🧪 Experiment<br/>mlp experiments create<br/>target_column + problem_type"]
    E --> Q["📋 Training Queue<br/>FIFO asyncio worker<br/>单任务顺序执行"]
    Q --> T["⚙ sklearn Train<br/>LabelEncoder → split<br/>RandomForest → fit"]
    T --> M["📈 MLflow Track<br/>log_metric + log_model<br/>mlflow_run_id 写回 DB"]
    M --> R["🤖 Register Model<br/>mlp models register<br/>version + framework"]
    R --> D["🚀 Deploy<br/>mlp deployments create<br/>内存加载 / Ray Serve"]
    D --> I["🔮 Predict<br/>mlp deployments predict<br/>{features} → prediction"]
    I --> L["📊 Monitor<br/>延迟/错误率/漂移<br/>InferenceLog → DB"]

    style U fill:#1e3a5f,stroke:#60a5fa,color:#e2e8f0
    style P fill:#1e293b,stroke:#93c5fd,color:#e2e8f0
    style E fill:#1e3a5f,stroke:#60a5fa,color:#e2e8f0
    style Q fill:#1e293b,stroke:#bbf7d0,color:#e2e8f0
    style T fill:#1e3a5f,stroke:#fbbf24,color:#e2e8f0
    style M fill:#1e293b,stroke:#fed7aa,color:#e2e8f0
    style R fill:#1e3a5f,stroke:#93c5fd,color:#e2e8f0
    style D fill:#1e3a5f,stroke:#fbbf24,color:#e2e8f0
